DATABASE_URL="postgresql://assistant:assistant@localhost:5432/assistant"
REDIS_URL="redis://localhost:6379"

# LLM Provider API Keys (BYOK - Bring Your Own Keys)
# Add your API keys here for the providers you want to use
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# Optional: Default model for LLM-as-judge scoring
# Format: provider:model-id (e.g., openai:gpt-4o-mini, anthropic:claude-sonnet-4-20250514)
# Can be overridden per TestRun via llmJudgeModel field
LLM_JUDGE_MODEL="openai:gpt-5-mini-2025-08-07"

# Optional: Default system prompt for LLM-as-judge
# Can be overridden per TestRun via llmJudgePrompt field
# LLM_JUDGE_PROMPT="You are an expert evaluator..."

# Optional: Embedding model for cosine similarity
# Used for semantic similarity scoring
EMBEDDING_MODEL="openai:text-embedding-3-small"

# Optional: Audio model for direct audio input (multimodal)
AUDIO_MODEL="openai:gpt-4o-audio-preview"